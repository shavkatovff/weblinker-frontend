# Serverdagi /opt/weblinker/.env ga nusxalang (yoki loyiha ildizi).
# Ishlab chiqarishda NODE_ENV=production bo‘lsin.

NODE_ENV=production

# PostgreSQL (masalan, oddiy: localhost yoki alohida host)
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/weblinker_db"

# JWT — uzun va tasodifiy qiymatlar (dev qiymatlarini qayta ishlatmang)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING=false
NEXT_PUBLIC_TELEGRAM_BOT=weblinkeruz_bot

# Domenlar (HTTPS)
# Frontend brauzerdan chaqiradi — build vaqtida NEXT_PUBLIC_* bake bo‘ladi
NEXT_PUBLIC_API_URL=https://api.weblinker.uz
# Billing / CLICK ko‘rsatmalari uchun ochiq sayt manzili (subdomen shart emas)
NEXT_PUBLIC_APP_URL=https://weblinker.uz

# Nest CORS: vergul bilan bir nechta manba
FRONTEND_ORIGIN=https://weblinker.uz,https://www.weblinker.uz

# Ichki portlar (dev bilan bir xil: web 8000, API 8001)
WEBLINKER_WEB_PORT=8000
WEBLINKER_API_PORT=8001
PORT=8000
API_PORT=8001

# Next `next.config.js` rewrites (CLICK) — http://127.0.0.1:<WEBLINKER_API_PORT>
INTERNAL_API_URL=http://127.0.0.1:8001

# CLICK (merchant kabinetida Prepare/Complete: https://weblinker.uz/api/payments/click/...)
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=
