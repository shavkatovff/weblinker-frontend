# /etc/nginx/sites-available/weblinker ga nusxalang, keyin:
#   sudo ln -s /etc/nginx/sites-available/weblinker /etc/nginx/sites-enabled/
#
# Bir serverda nechta loyiha bo'lsa: har domen alohida server_name + weblinker uchun
# alohida portlar (boshqa loyiha weblinker portini band qilmasin). Muammo: deploy/NGINX-MULTI-SITE.md
#
# Avval HTTP (80) bilan tekshirib, keyin certbot:
#   sudo certbot --nginx -d weblinker.uz -d www.weblinker.uz -d api.weblinker.uz
#
# Bitta sertifikat barcha domenlar uchun (SAN) — yo‘llar odatda shunday:
#   ssl_certificate     /etc/letsencrypt/live/weblinker.uz/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/weblinker.uz/privkey.pem;
#
# Next.js (weblinker.uz) va Nest API — PM2: 127.0.0.1:8000 va :8001
# api.weblinker.uz — SPA uchun ixtiyoriy (NEXT_PUBLIC_API_URL ga qarab).
#
# Certbot dan keyin HTTPS (443) server bloklarida ham — birinchi domen uchun —
# shu `location /api/payments/click/` ni takrorlang (yoki faqat Next rewrites yetadi).

upstream weblinker_next {
    # .env da WEBLINKER_WEB_PORT bilan mos (odat 8000)
    server 127.0.0.1:8000;
    keepalive 64;
}

upstream weblinker_api {
    # .env da WEBLINKER_API_PORT bilan mos
    server 127.0.0.1:8001;
    keepalive 64;
}

# HTTP → HTTPS (certbot bundan keyin SSL bloklarini qo‘shishi mumkin)
server {
    listen 80;
    listen [::]:80;
    server_name weblinker.uz www.weblinker.uz;

    # Nest API — asosiy domen orqali (api.weblinker.uz DNS shart emas). 443 blokda ham xuddi shu.
    location /auth {
        proxy_pass http://weblinker_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 25m;
    }
    location /vizitka {
        proxy_pass http://weblinker_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 25m;
    }
    location /telegram {
        proxy_pass http://weblinker_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 25m;
    }
    location /payments {
        proxy_pass http://weblinker_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 25m;
    }
    location = /health {
        proxy_pass http://weblinker_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # CLICK Prepare/Complete
    location /api/payments/click/ {
        proxy_pass http://weblinker_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 25m;
    }

    location / {
        proxy_pass http://weblinker_next;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name api.weblinker.uz;
    location / {
        proxy_pass http://weblinker_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 25m;
    }
}
