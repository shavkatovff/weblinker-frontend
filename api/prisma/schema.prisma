generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Lang {
  UZ
  RU
  EN
}

// Ro'yxatdan o'tgan foydalanuvchi. Kirish kodi: loginOtp (Telegram orqali), 2 daqiqagacha
model User {
  id                Int       @id @default(autoincrement())
  
  publicId          String    @unique @default(cuid()) @map("public_id")
  number            String    @unique
  
  telegramId        String?   @unique @map("telegram_id")

  loginOtp          String?   @map("login_otp")
  loginOtpExpiresAt DateTime? @map("login_otp_expires_at")

  userId            String?   @unique @map("user_id")
  username          String?
  fullName          String?   @map("full_name")
  
  refreshToken      String?   @map("refresh_token")
  refreshTokenExp   DateTime? @map("refresh_token_exp")
  balance           Decimal   @default(0) @db.Decimal(12, 2)
  lang              Lang      @default(UZ)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  vizitkas Vizitka[]
  payments Payment[]
  landings Landing[]

  @@map("users")
}

/// CLICK balans to‘lovi (Prepare → Complete)
model Payment {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  /// CLICK Prepare/Complete `amount` — so'm (butun son, hujjatga mos)
  amount            Int
  status            String    @default("PENDING")

  merchantTransId   String    @unique @map("merchant_trans_id")
  clickTransId      String?   @map("click_trans_id")
  clickPaydocId     String?   @map("click_paydoc_id")
  merchantPrepareId Int?      @map("merchant_prepare_id")
  merchantConfirmId Int?      @map("merchant_confirm_id")

  createdAt         DateTime  @default(now()) @map("created_at")
  paidAt            DateTime? @map("paid_at")

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payments")
}

// Ro'yxatdan o'tmagan: bot kontakt yuborishi bilan vaqtincha, sayt kodi to'g'ri kelsa users ga ko'chiriladi
model TgUser {
  id                 Int      @id @default(autoincrement())
  /// Telegram `from.id` (string)
  telegramUserId     String   @unique @map("userId")
  username           String?
  number             String   @unique
  fullName           String?  @map("full_name")
  loginOtp           String?  @map("login_otp")
  loginOtpExpiresAt  DateTime? @map("login_otp_expires_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("tg_users")
}

/// Vizitka tarif — weblinker.uz/{name} (name noyob slug)
model Vizitka {
  id     String  @id @default(cuid())
  user   User   @relation(fields: [ownerPublicId], references: [publicId], onDelete: Cascade)
  /// Foydalanuvchini `users.public_id` orqali bog‘lash (ichki `id` emas)
  ownerPublicId String @map("owner_public_id")

  plan  String  @default("10kun")
  /// Obuna muddati tugaguncha
  expiredAt DateTime? @map("expired_at")

  /// Manzil: /{name} noyob (faqat a-z, 0-9, -)
  name  String  @unique
  /// Brend / biznes nomi (sarlavha)
  headline  String?
  category  String?
  /// Hero/katta rasm URL (to‘liq yoki `/uploads/...`)
  photoUrl  String?  @map("photo_url")
  /// Logo fayli URL — `uploads/logos/` dan
  logoUrl   String?  @map("logo_url")
  contactNumber  String?  @map("contact_number")
  address  String?
  workHour  String?  @map("work_hour")
  shortDescription  String?  @map("short_description")
  description  String?  @map("description")

  /// Shablon, dizayn (tahrirchi bilan sinxron)
  templateId  String?  @map("template_id")
  colorThemeId  String?  @map("color_theme_id")
  patternId  String?  @map("pattern_id")

  status  VizitkaStatus  @default(DRAFT)

  /// Muddat tugashi haqidagi Telegram xabari yuborilgan vaqt (takrorlanmas)
  expiryNoticeSentAt DateTime? @map("expiry_notice_sent_at")

  mapLink  String?  @map("map_link")
  instagramLink  String?  @map("instagram_link")
  telegramLink  String?  @map("telegram_link")
  tiktokLink  String?  @map("tiktok_link")
  youtubeLink  String?  @map("youtube_link")
  facebookLink  String?  @map("facebook_link")
  linkedinLink  String?  @map("linkedin_link")
  xLink  String?  @map("x_link")
  threadsLink  String?  @map("threads_link")
  whatsappLink  String?  @map("whatsapp_link")
  websaytLink  String?  @map("website_link")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([ownerPublicId])
  @@index([name])
  @@index([status])
  @@map("vizitkas")
}

enum VizitkaStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

/// Platforma sozlamalari (yagona qator, id = 1): bepul kunlar va paket narxlari (so'm)
model AppSettings {
  id Int @id @default(1)

  freePublishDays Int @default(10) @map("free_publish_days")
  paket3Som       Int @default(37000) @map("paket_3_som")
  paket6Som       Int @default(75000) @map("paket_6_som")
  paket12Som      Int @default(125000) @map("paket_12_som")
  /// Landing sayt paketlari (so'm) — vizitka narxlari bilan mustaqil
  landingPaket6Som  Int @default(780000) @map("landing_paket_6_som")
  landingPaket12Som Int @default(1180000) @map("landing_paket_12_som")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}





/// Landing tarif — weblinker.uz/{name} (name noyob slug)
model Landing {
  id     String  @id @default(cuid())
  /// Foydalanuvchini `users.public_id` orqali bog‘lash (ichki `id` emas)
  user   User   @relation(fields: [ownerPublicId], references: [publicId], onDelete: Cascade)
  ownerPublicId String @map("owner_public_id")

  /// Manzil: /{name} noyob (faqat a-z, 0-9, -)
  name  String  @unique
  plan  String  @default("10kun")
  /// Obuna muddati tugaguncha
  expiredAt DateTime? @map("expired_at")

  /// Bo'limlarni yoqish / o'chirish
  blockHeader   Boolean  @default(true) @map("block_header")
  blockHero     Boolean  @default(true) @map("block_hero")
  blockAbout    Boolean  @default(true) @map("block_about")
  blockFaq      Boolean  @default(true) @map("block_faq")
  blockContact  Boolean  @default(true) @map("block_contact")
  blockFooter   Boolean  @default(true) @map("block_footer")
  /// Dizayn shabloni: "1" | "2" | "3" | "4"
  blocktheme    String   @default("1") @map("block_theme")

  /// Brend va navigatsiya
  brandName     String   @default("Mening saytim") @map("brand_name")
  navAbout      String   @default("Biz haqimizda") @map("nav_about")
  navFaq        String   @default("FAQ") @map("nav_faq")
  navContact    String   @default("Aloqa") @map("nav_contact")
  navCta        String   @default("Bog'lanish") @map("nav_cta")

  /// Hero bo'limi
  heroTitle     String   @default("") @map("hero_title") @db.Text
  heroCta       String   @default("Bog'lanish") @map("hero_cta")
  heroImageUrl  String   @default("") @map("hero_image_url") @db.Text

  /// Biz haqimizda
  aboutTitle    String   @default("") @map("about_title") @db.Text
  aboutLead     String   @default("") @map("about_lead") @db.Text
  aboutImageUrl String   @default("") @map("about_image_url") @db.Text
  aboutBullet1  String   @default("") @map("about_bullet_1")
  aboutBullet2  String   @default("") @map("about_bullet_2")
  aboutBullet3  String   @default("") @map("about_bullet_3")
  aboutBullet4  String   @default("") @map("about_bullet_4")

  /// FAQ
  faq1Q         String   @default("") @map("faq_1_q")
  faq1A         String   @default("") @map("faq_1_a") @db.Text
  faq2Q         String   @default("") @map("faq_2_q")
  faq2A         String   @default("") @map("faq_2_a") @db.Text
  faq3Q         String   @default("") @map("faq_3_q")
  faq3A         String   @default("") @map("faq_3_a") @db.Text
  faq4Q         String   @default("") @map("faq_4_q")
  faq4A         String   @default("") @map("faq_4_a") @db.Text

  /// Aloqa
  contactSubtitle String @default("") @map("contact_subtitle") @db.Text
  address         String @default("")
  phoneTel        String @default("") @map("phone_tel")
  telegram        String @default("") @map("telegram")
  hours           String @default("")

  /// Footer
  footerCopyrightSuffix String @default("") @map("footer_copyright_suffix")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerPublicId])
  @@map("landings")
}
